{
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/support",
      "destination": "/support.html"
    },
    {
      "source": "/privacy", 
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/about",
      "destination": "/executive-summary.html"
    },
    {
      "source": "/ibd-crohns-support",
      "destination": "/ibd-crohns-support.html"
    },
    {
      "source": "/blog/best-foods-crohns-flare",
      "destination": "/blogs/best-foods-crohns-flare.html"
    },
    {
      "source": "/blog/foods-that-may-trigger-uc-symptoms",
      "destination": "/blogs/foods-that-may-trigger-uc-symptoms.html"
    },
    {
      "source": "/blog/how-nutrition-impacts-gut-health-ibd",
      "destination": "/blogs/how-nutrition-impacts-gut-health-ibd.html"
    },
    {
      "source": "/blog/hydration-tips-ibd",
      "destination": "/blogs/hydration-tips-ibd.html"
    },
    {
      "source": "/blog/tracking-food-symptoms-ibdpal",
      "destination": "/blogs/tracking-food-symptoms-ibdpal.html"
    },
    {
      "source": "/blog/introducing-ibdpal",
      "destination": "/blogs/introducing-ibdpal.html"
    },
    {
      "source": "/blog/low-residue-diet-flare",
      "destination": "/blogs/low-residue-diet-flare.html"
    },
    {
      "source": "/blog/travel-with-ibd",
      "destination": "/blogs/travel-with-ibd.html"
    },
    {
      "source": "/blog/understanding-biologics-ibd",
      "destination": "/blogs/understanding-biologics-ibd.html"
    },
    {
      "source": "/blog/living-with-ibd-kids",
      "destination": "/blogs/living-with-ibd-kids.html"
    },
    {
      "source": "/blog/stress-emotional-wellness-ibd",
      "destination": "/blogs/stress-emotional-wellness-ibd.html"
    },
    {
      "source": "/blog/sleep-rest-ibd-flares",
      "destination": "/blogs/sleep-rest-ibd-flares.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}





